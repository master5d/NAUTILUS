# docker/.env — secrets for docker-compose.yml (copy to .env, fill real values)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(24))"
#
# ⚠ Existing volumes keep their ORIGINAL passwords (postgres/neo4j set them on
# first init only). To rotate: change inside the running DB first, then here.

LANGFUSE_DB_PASSWORD=
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
NEO4J_PASSWORD=
KARAKEEP_DB_PASSWORD=
KARAKEEP_NEXTAUTH_SECRET=
